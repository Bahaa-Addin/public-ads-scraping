# Ignore all data files but keep directory structure
*

# Keep gitignore and gitkeep files
!.gitignore
!.gitkeep

# Keep placeholder JSON files (empty structure)
!db/
!db/.gitkeep
!db/jobs.json
!db/assets.json

!metrics/
!metrics/.gitkeep
!metrics/system_metrics.json
!metrics/time_series.json
!metrics/scraper_status.json

!logs/
!logs/.gitkeep
!logs/pipeline.log

!files/
!files/.gitkeep
!files/screenshots/
!files/screenshots/.gitkeep

# Ignore actual scraped data
assets/
files/processed/
files/raw/
