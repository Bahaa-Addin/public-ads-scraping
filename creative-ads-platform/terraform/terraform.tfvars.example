# Creative Ads Platform - Terraform Variables Example
# Copy this file to terraform.tfvars and fill in your values
#
# ⚠️  COST-OPTIMIZED DEFAULTS FOR TESTING
# These settings are configured for minimal costs during development/testing.
# Adjust values for production workloads.

# =============================================================================
# Required Variables
# =============================================================================

project_id = "your-gcp-project-id"
region     = "us-central1"

# =============================================================================
# Environment
# =============================================================================

environment = "development"  # development, staging, production

# =============================================================================
# Container Images
# =============================================================================

# Update these after building and pushing your images
agent_image   = "us-central1-docker.pkg.dev/your-project/creative-ads/agent:latest"
scraper_image = "us-central1-docker.pkg.dev/your-project/creative-ads/scraper:latest"

# =============================================================================
# Cloud Run Scaling (Cost-Optimized)
# =============================================================================
#
# ⚠️  IMPORTANT: These settings are optimized for MINIMAL COST during testing.
# For production, consider increasing max_instances based on expected load.
#
# Cost savings:
# - min_instances = 0: No cost when idle (cold starts may occur)
# - max_instances = 1: Limits maximum concurrent instances

agent_min_instances   = 0   # Scale to zero when idle
agent_max_instances   = 1   # Maximum 1 instance for testing (prod: 10+)
scraper_min_instances = 0   # Scale to zero when idle
scraper_max_instances = 1   # Maximum 1 instance for testing (prod: 20+)

# =============================================================================
# Resource Limits (Cost-Optimized)
# =============================================================================
#
# ⚠️  These are minimal resource allocations for testing.
# For production workloads, especially the scraper (Puppeteer), increase these.
#
# Recommended production values:
#   agent_cpu = "1", agent_memory = "1Gi"
#   scraper_cpu = "2", scraper_memory = "2Gi"

agent_cpu      = "0.25"    # 0.25 vCPU (minimum for testing)
agent_memory   = "512Mi"   # 512MB RAM
scraper_cpu    = "0.25"    # 0.25 vCPU (minimum for testing)
scraper_memory = "512Mi"   # 512MB RAM (may need more for Puppeteer)

# =============================================================================
# Firestore
# =============================================================================

firestore_location          = "nam5"
firestore_collection_prefix = "creative_ads"

# =============================================================================
# BigQuery (Optional - disable for cost savings)
# =============================================================================

enable_bigquery   = false   # Disable for testing (saves costs)
bigquery_location = "US"

# =============================================================================
# Vertex AI
# =============================================================================

vertex_ai_model = "gemini-1.5-flash"  # Use flash model for lower costs

# =============================================================================
# Scheduled Scraping (Optional)
# =============================================================================

enable_scheduled_scraping = false     # Disable for testing
scraping_schedule         = "0 */6 * * *"  # Every 6 hours (when enabled)

# =============================================================================
# Monitoring & Alerting
# =============================================================================

enable_monitoring_alerts = true
notification_channels    = []  # Add your notification channel IDs

# =============================================================================
# Budget Alerts (Cost Control) - RECOMMENDED
# =============================================================================
#
# Enable budget alerts to get notified before costs get out of control.
# You'll need your GCP Billing Account ID (format: XXXXXX-XXXXXX-XXXXXX)
# Find it at: https://console.cloud.google.com/billing

enable_budget_alerts    = true
billing_account_id      = null  # Set to your billing account ID, e.g., "012345-678901-ABCDEF"
budget_amount           = 50    # Monthly budget in USD
budget_alert_thresholds = [50, 80, 100]  # Alert at 50%, 80%, and 100% of budget
budget_alert_emails     = []    # Add email addresses for alerts

# =============================================================================
# Network (Optional)
# =============================================================================

# vpc_connector = "projects/your-project/locations/us-central1/connectors/your-connector"
