# =============================================================================
# Public Ads Platform - Repository Environment Reference
# =============================================================================
# Copy this file to `platform/.env` for local development. The defaults keep the
# platform runnable in local mode with no cloud credentials. Cloud-only values
# should be filled in only when MODE=cloud.

# -----------------------------------------------------------------------------
# Runtime mode
# -----------------------------------------------------------------------------
MODE=local
ENVIRONMENT=development
LOG_LEVEL=INFO
DATA_DIR=./data

# -----------------------------------------------------------------------------
# Local-first LLM/runtime defaults
# -----------------------------------------------------------------------------
LLM_MODE=template
HEADLESS=true
REQUEST_DELAY_MS=1000
PAGE_TIMEOUT_MS=30000
MAX_CONCURRENT_JOBS=10
JOB_TIMEOUT_SECONDS=300
HEALTH_CHECK_INTERVAL_SECONDS=60

# Low-resource local settings
MAX_BROWSER_INSTANCES=1
SEQUENTIAL_SCRAPING=true
GLOBAL_JOB_CAP=100
MAX_QUEUE_SIZE=1000
MAX_ASSETS_IN_MEMORY=50

# -----------------------------------------------------------------------------
# Local service URLs and ports
# -----------------------------------------------------------------------------
API_PORT=8081
SCRAPER_API_URL=http://localhost:3001
AGENT_API_URL=http://localhost:8081
VITE_API_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Source-specific rate limits
META_RATE_LIMIT=30
GOOGLE_RATE_LIMIT=60
ARCHIVE_RATE_LIMIT=120
WIKIMEDIA_RATE_LIMIT=100

# -----------------------------------------------------------------------------
# Cloud mode settings (leave blank in local mode)
# -----------------------------------------------------------------------------
GCP_PROJECT_ID=
GCP_REGION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=
FIRESTORE_COLLECTION_PREFIX=creative_ads
FIRESTORE_DATABASE_ID=(default)
STORAGE_BUCKET_RAW=
STORAGE_BUCKET_PROCESSED=
PUBSUB_TOPIC=public-ads-jobs
PUBSUB_SUBSCRIPTION=public-ads-jobs-sub
PUBSUB_DLQ_TOPIC=public-ads-jobs-dlq
BIGQUERY_ENABLED=false
BIGQUERY_DATASET=creative_ads_analytics
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_MODEL=gemini-1.5-pro
ENABLE_CLOUD_MONITORING=false
ENABLE_CLOUD_LOGGING=false

# -----------------------------------------------------------------------------
# Dashboard/auth settings
# -----------------------------------------------------------------------------
SECRET_KEY=replace-me-for-cloud-mode
API_KEY=
