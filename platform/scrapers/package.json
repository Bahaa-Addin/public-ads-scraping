{
  "name": "agentic-ads-scrapers",
  "version": "1.0.0",
  "description": "Playwright-based scrapers for agentic ads from multiple public sources",
  "main": "scraper.js",
  "type": "module",
  "scripts": {
    "start": "node scraper.js",
    "server": "node server.js",
    "scrape:meta": "node scraper.js --source meta_ad_library",
    "scrape:google": "node scraper.js --source google_ads_transparency",
    "scrape:archive": "node scraper.js --source internet_archive",
    "scrape:wikimedia": "node scraper.js --source wikimedia_commons",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@google-cloud/pubsub": "^4.1.0",
    "@google-cloud/storage": "^7.7.0",
    "axios": "^1.6.2",
    "commander": "^11.1.0",
    "dotenv": "^16.3.1",
    "p-queue": "^8.0.1",
    "p-retry": "^6.1.0",
    "playwright": "^1.40.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "sharp": "^0.33.5",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "eslint": "^8.55.0",
    "prettier": "^3.1.0",
    "vitest": "^1.0.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "scraper",
    "playwright",
    "ads",
    "creative",
    "automation"
  ],
  "author": "Agentic Ads Platform",
  "license": "MIT"
}
