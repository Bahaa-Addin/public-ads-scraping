# Agentic Ads Dashboard Backend Configuration
# Copy this file to .env, fill in your values, and keep the real file out of git.

# =============================================================================
# Application
# =============================================================================

ENVIRONMENT=development
DEBUG=true

# =============================================================================
# GCP Configuration
# =============================================================================

GCP_PROJECT_ID=your-gcp-project-id
GCP_PROJECT_NUMBER=
GCP_REGION=us-central1

# Service Account
SERVICE_ACCOUNT_EMAIL=your-sa@your-project.iam.gserviceaccount.com

# =============================================================================
# Firestore
# =============================================================================

FIRESTORE_PROJECT_ID=your-gcp-project-id
FIRESTORE_DATABASE_ID=(default)
FIRESTORE_COLLECTION_PREFIX=creative_ads

# =============================================================================
# Cloud Storage
# =============================================================================

STORAGE_BUCKET_RAW=your-project-raw-assets
STORAGE_BUCKET_PROCESSED=your-project-processed-assets

# =============================================================================
# Pub/Sub
# =============================================================================

PUBSUB_PROJECT_ID=your-gcp-project-id
PUBSUB_TOPIC=agentic-ads-jobs
PUBSUB_SUBSCRIPTION=agentic-ads-jobs-sub
PUBSUB_DLQ_TOPIC=agentic-ads-jobs-dlq

# =============================================================================
# BigQuery
# =============================================================================

BIGQUERY_DATASET=creative_ads_analytics
BIGQUERY_ENABLED=false

# =============================================================================
# Services
# =============================================================================

AGENT_API_URL=http://localhost:8081
SCRAPER_API_URL=http://localhost:3001

# =============================================================================
# Vertex AI
# =============================================================================

VERTEX_AI_PROJECT_ID=your-gcp-project-id
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_MODEL=gemini-pro
VERTEX_AI_ENDPOINT_ID=

# =============================================================================
# Security
# =============================================================================

SECRET_KEY=replace-with-a-random-string
API_KEY=optional-local-api-key

# =============================================================================
# CORS (comma-separated)
# =============================================================================

CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# =============================================================================
# Monitoring
# =============================================================================

MONITORING_PROJECT_ID=your-gcp-project-id
LOG_NAME=projects/your-project-id/logs/your-app
ENABLE_METRICS=true
ENABLE_CLOUD_LOGGING=false
LOG_LEVEL=INFO

# =============================================================================
# Cache
# =============================================================================

CACHE_TTL_SECONDS=60
