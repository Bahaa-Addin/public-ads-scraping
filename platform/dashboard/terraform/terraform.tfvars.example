# =============================================================================
# Agentic Ads Dashboard - Terraform Variables Example
# =============================================================================
# Copy this file to terraform.tfvars and fill in your values

# Required
project_id = "your-gcp-project-id"
region     = "us-central1"

# Service Configuration
service_name = "agentic-ads-dashboard"
environment  = "development"  # development, staging, or production
image_tag    = "latest"

# API Configuration
api_cpu           = "1"
api_memory        = "512Mi"
api_min_instances = 0
api_max_instances = 10

# Frontend Configuration
frontend_cpu           = "1"
frontend_memory        = "256Mi"
frontend_min_instances = 0
frontend_max_instances = 5

# Backend Configuration
firestore_collection_prefix = "creative_ads"
pubsub_topic               = "agentic-ads-jobs"
pubsub_subscription        = "agentic-ads-jobs-sub"

# Set these to your existing service URLs
agent_service_url   = "https://agentic-ads-agent-xxxxx.run.app"
scraper_service_url = "https://agentic-ads-scraper-xxxxx.run.app"

# Security
allow_unauthenticated = true
cors_origins         = ["*"]

# Monitoring - Add notification channel IDs for alerts
notification_channels = []

