# =============================================================================
# Agentic Ads Dashboard - Environment Variables
# =============================================================================
# Copy this file to .env, fill in your values, and keep the real file out of git.

# =============================================================================
# GCP Configuration
# =============================================================================

GCP_PROJECT_ID=your-gcp-project-id
GCP_PROJECT_NUMBER=
GCP_REGION=us-central1

# Service Account
SERVICE_ACCOUNT_EMAIL=your-sa@your-project.iam.gserviceaccount.com

# =============================================================================
# Firestore Configuration
# =============================================================================

FIRESTORE_PROJECT_ID=your-gcp-project-id
FIRESTORE_DATABASE_ID=(default)
FIRESTORE_COLLECTION_PREFIX=creative_ads

# =============================================================================
# Pub/Sub Configuration
# =============================================================================

PUBSUB_PROJECT_ID=your-gcp-project-id
PUBSUB_TOPIC=agentic-ads-jobs
PUBSUB_SUBSCRIPTION=agentic-ads-jobs-sub
PUBSUB_DLQ_TOPIC=agentic-ads-jobs-dlq

# =============================================================================
# Service URLs
# =============================================================================

# For local development
AGENT_API_URL=http://localhost:8081
SCRAPER_API_URL=http://localhost:3001
API_URL=http://localhost:8000

# For production, use Cloud Run URLs:
# AGENT_API_URL=https://your-agent-service.run.app
# SCRAPER_API_URL=https://your-scraper-service.run.app
# API_URL=https://your-api-service.run.app

# =============================================================================
# Frontend Configuration
# =============================================================================

VITE_API_URL=http://localhost:8000

# =============================================================================
# Emulator Configuration (for local development)
# =============================================================================

USE_EMULATOR=false
# FIRESTORE_EMULATOR_HOST=localhost:8080
# PUBSUB_EMULATOR_HOST=localhost:8085

# =============================================================================
# Logging
# =============================================================================

LOG_LEVEL=DEBUG

# =============================================================================
# Docker Registry (for CI/CD)
# =============================================================================

REGISTRY_URL=us-central1-docker.pkg.dev/your-project/agentic-ads-dashboard
IMAGE_TAG=latest
ARTIFACT_REGISTRY_REPO=agentic-ads-dashboard

# =============================================================================
# Terraform
# =============================================================================

TERRAFORM_STATE_BUCKET=your-terraform-state-bucket

# =============================================================================
# Notifications (optional)
# =============================================================================

SLACK_WEBHOOK_URL=

# =============================================================================
# CORS Configuration
# =============================================================================

CORS_ORIGINS=http://localhost:5173,http://localhost:3000
