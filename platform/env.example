# Agentic Ads Platform - Environment Variables Example
# Copy this file to .env, fill in your values, and keep the real file out of git.

# =============================================================================
# GCP Configuration
# =============================================================================

# Your Google Cloud project ID
GCP_PROJECT_ID=your-project-id

# Your Google Cloud project number
GCP_PROJECT_NUMBER=

# GCP region for resources
GCP_REGION=us-central1

# Path to a local-only service account key file (do not commit it)
GOOGLE_APPLICATION_CREDENTIALS=./service-account-key.json

# =============================================================================
# Service Account Configuration
# =============================================================================

# Service account email
SERVICE_ACCOUNT_EMAIL=your-sa@your-project.iam.gserviceaccount.com

# Service account ID
SERVICE_ACCOUNT_ID=

# =============================================================================
# Cloud Run Configuration
# =============================================================================

# Cloud Run service name
CLOUD_RUN_SERVICE_NAME=your-scraper-service

# Cloud Run service URL (after deployment)
CLOUD_RUN_URL=https://your-service-url.run.app

# Cloud Run service account
CLOUD_RUN_SERVICE_ACCOUNT=your-sa@your-project.iam.gserviceaccount.com

# =============================================================================
# Pub/Sub Configuration
# =============================================================================

# Pub/Sub project ID (usually same as GCP_PROJECT_ID)
PUBSUB_PROJECT_ID=your-project-id

# Main topic for job processing
PUBSUB_TOPIC=agentic-ads-jobs

# Main subscription
PUBSUB_SUBSCRIPTION=agentic-ads-jobs-sub

# Dead letter queue topic
PUBSUB_DLQ_TOPIC=agentic-ads-jobs-dlq

# Dead letter queue subscription
PUBSUB_DLQ_SUBSCRIPTION=agentic-ads-jobs-dlq-sub

# Maximum messages to pull at once
PUBSUB_MAX_MESSAGES=100

# Acknowledgment deadline in seconds
PUBSUB_ACK_DEADLINE=10

# =============================================================================
# Storage Configuration
# =============================================================================

# Bucket for raw scraped assets
STORAGE_BUCKET_RAW=your-project-raw-assets

# Bucket for processed assets
STORAGE_BUCKET_PROCESSED=your-project-processed-assets

# =============================================================================
# Firestore Configuration
# =============================================================================

# Firestore project ID (usually same as GCP_PROJECT_ID)
FIRESTORE_PROJECT_ID=your-project-id

# Firestore database ID
FIRESTORE_DATABASE_ID=(default)

# Collection prefix for all collections
FIRESTORE_COLLECTION_PREFIX=creative_ads

# =============================================================================
# BigQuery Configuration (Optional)
# =============================================================================

BIGQUERY_ENABLED=false
BIGQUERY_DATASET=creative_ads_analytics

# =============================================================================
# Vertex AI Configuration
# =============================================================================

# Vertex AI project ID (usually same as GCP_PROJECT_ID)
VERTEX_AI_PROJECT_ID=your-project-id

# Vertex AI location/region
VERTEX_AI_LOCATION=us-central1

# Model to use for AI features
VERTEX_AI_MODEL=gemini-pro

# Custom endpoint ID (optional)
VERTEX_AI_ENDPOINT_ID=

# =============================================================================
# Cloud Monitoring Configuration
# =============================================================================

# Monitoring project ID (usually same as GCP_PROJECT_ID)
MONITORING_PROJECT_ID=your-project-id

# Log name for Cloud Logging
LOG_NAME=projects/your-project-id/logs/your-app

# Enable cloud monitoring
ENABLE_CLOUD_MONITORING=true

# Enable cloud logging
ENABLE_CLOUD_LOGGING=true

# =============================================================================
# Agent Configuration
# =============================================================================

MAX_CONCURRENT_JOBS=10
JOB_TIMEOUT_SECONDS=300
HEALTH_CHECK_INTERVAL_SECONDS=60

# =============================================================================
# Logging Configuration
# =============================================================================

LOG_LEVEL=INFO

# =============================================================================
# Scraper Configuration
# =============================================================================

# Run browser in headless mode (set to false for debugging)
HEADLESS=true

# Rate limits per minute
META_RATE_LIMIT=30
GOOGLE_RATE_LIMIT=60
ARCHIVE_RATE_LIMIT=120
WIKIMEDIA_RATE_LIMIT=100

# =============================================================================
# Environment Settings
# =============================================================================

# Set to 'development' for local development, 'production' for prod
ENVIRONMENT=development

# Node environment
NODE_ENV=development

# Enable debug mode
DEBUG=true

# =============================================================================
# Local Development (uncomment for emulators)
# =============================================================================

# FIRESTORE_EMULATOR_HOST=localhost:8080
# PUBSUB_EMULATOR_HOST=localhost:8085
